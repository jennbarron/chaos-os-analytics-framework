<svg viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <!-- Define styles -->
  <defs>
    <style>
      .box-main { fill: #2c3e50; stroke: #3498db; stroke-width: 2; }
      .box-layer { fill: #34495e; stroke: #9b59b6; stroke-width: 2; }
      .box-spoke { fill: #16a085; stroke: #1abc9c; stroke-width: 1.5; }
      .text-main { font-family: 'Segoe UI', sans-serif; font-size: 14px; font-weight: bold; fill: #ecf0f1; }
      .text-sub { font-family: 'Segoe UI', sans-serif; font-size: 12px; fill: #bdc3c7; }
      .text-title { font-family: 'Segoe UI', sans-serif; font-size: 16px; font-weight: bold; fill: #3498db; }
      .arrow { stroke: #95a5a6; stroke-width: 2; fill: none; marker-end: url(#arrowhead); }
      .arrow-dashed { stroke: #95a5a6; stroke-width: 1.5; stroke-dasharray: 4,4; fill: none; marker-end: url(#arrowhead); }
    </style>
    <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#95a5a6" />
    </marker>
  </defs>

  <!-- Title -->
  <text x="400" y="30" text-anchor="middle" class="text-title">ChaosOS™ Architecture</text>

  <!-- User Input -->
  <rect x="300" y="50" width="200" height="50" rx="5" class="box-main"/>
  <text x="400" y="82" text-anchor="middle" class="text-main">User</text>

  <!-- Arrow down -->
  <path d="M 400 100 L 400 140" class="arrow"/>

  <!-- ChaosOS Core -->
  <rect x="280" y="140" width="240" height="50" rx="5" class="box-main"/>
  <text x="400" y="172" text-anchor="middle" class="text-main">ChaosOS Core</text>

  <!-- Arrow down -->
  <path d="M 400 190 L 400 230" class="arrow"/>

  <!-- Domain Categories Row -->
  <rect x="50" y="230" width="120" height="45" rx="4" class="box-layer"/>
  <text x="110" y="252" text-anchor="middle" class="text-sub">Career</text>
  <text x="110" y="267" text-anchor="middle" class="text-sub">Business</text>

  <rect x="190" y="230" width="120" height="45" rx="4" class="box-layer"/>
  <text x="250" y="252" text-anchor="middle" class="text-sub">Medical</text>
  <text x="250" y="267" text-anchor="middle" class="text-sub">Projects</text>

  <rect x="330" y="230" width="140" height="45" rx="4" class="box-layer"/>
  <text x="400" y="252" text-anchor="middle" class="text-sub">Education</text>
  <text x="400" y="267" text-anchor="middle" class="text-sub">Research</text>

  <rect x="590" y="230" width="160" height="45" rx="4" class="box-layer"/>
  <text x="670" y="252" text-anchor="middle" class="text-sub">Finance</text>
  <text x="670" y="267" text-anchor="middle" class="text-sub">Relocation</text>

  <!-- Arrows from core to domains -->
  <path d="M 350 190 L 110 230" class="arrow-dashed"/>
  <path d="M 380 190 L 250 230" class="arrow-dashed"/>
  <path d="M 420 190 L 400 230" class="arrow-dashed"/>
  <path d="M 450 190 L 670 230" class="arrow-dashed"/>

  <!-- Arrow down from domains -->
  <path d="M 400 275 L 400 315" class="arrow"/>

  <!-- LifeVault -->
  <rect x="250" y="315" width="300" height="80" rx="5" class="box-main"/>
  <text x="400" y="340" text-anchor="middle" class="text-main">LifeVault</text>
  <text x="400" y="360" text-anchor="middle" class="text-sub">(Memory, Context, Documentation, Decisions)</text>
  <text x="400" y="380" text-anchor="middle" class="text-sub">BRG • SCX • LifeVaultDB</text>

  <!-- Arrow down -->
  <path d="M 400 395 L 400 435" class="arrow"/>

  <!-- Notion Database Layer -->
  <rect x="250" y="435" width="300" height="50" rx="5" class="box-main"/>
  <text x="400" y="468" text-anchor="middle" class="text-main">Notion Database Layer</text>

  <!-- Legend -->
  <text x="50" y="540" class="text-sub" font-size="11">33+ domain-specific agents distributed across:</text>
  <text x="50" y="560" class="text-sub" font-size="11">HEA/FHEA (medical) • LEG (legal) • MON/FIN (finance) • PER (safety/behavior) • TRV (travel) • JOB (career) • + more</text>

  <!-- Bottom note -->
  <text x="50" y="585" class="text-sub" font-size="10">Output: Consolidated plans, decisions, risk assessments, structured messages, ops workflows</text>
</svg>